{
  "name": "seekdesk",
  "version": "0.1.0",
  "private": true,
  "description": "DeepSeek-native AI ecosystem workspace for everyday productivity.",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/agent",
    "packages/config",
    "apps/web",
    "apps/api",
    "apps/daemon"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --workspace @seekdesk/web run dev",
    "dev:api": "npm --workspace @seekdesk/api run dev",
    "dev:daemon": "npm --workspace @seekdesk/daemon run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:browser-smoke": "node scripts/browser-smoke.cjs",
    "configure:google-oauth": "node scripts/configure-google-oauth-env.mjs",
    "sync:remote-google-oauth": "node scripts/sync-remote-google-oauth-env.mjs",
    "verify:google-oauth": "node scripts/google-oauth-readiness.mjs",
    "verify:remote-real-agent": "node scripts/verify-remote-real-agent.mjs",
    "verify:real-agent": "node scripts/verify-real-agent.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
